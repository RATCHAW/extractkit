# Copy to .env (git-ignored). The playground and the eval harness both read
# this single file from the repo root. Anything already set in your shell wins.

# Provider keys — set at least one; playground + evals use whichever are present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Playground — port the Hono API listens on; the Vite dev server proxies /api here.
PORT=8787

# Evals (optional)
EVAL_PROVIDERS=
EVAL_MODELS=
DOCILE_TOKEN=
